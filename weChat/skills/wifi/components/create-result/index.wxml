<view class="wifi-card">
  <view class="header">
    <text class="eyebrow">WiFi Studio</text>
    <text class="title">{{title}}</text>
  </view>
  <view class="body">
    <text class="label">网络名称</text>
    <text class="name">{{wifiName}}</text>
    <text class="desc">{{description}}</text>
  </view>
  <view class="actions">
    <button class="secondary-btn" hover-class="btn-hover" bindtap="onTapList">查看列表</button>
  </view>
</view>
