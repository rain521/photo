/* ratio=4:1，依据：创建结果为轻量状态展示。
 * 色源：app.json window.backgroundColor #F8F8F8 + pages/index/index.vue 页面主色 #0f8f57、文字色 #111827。
 * 暗黑：#F8F8F8 降明度到 #181818，描边 #E5E7EB 降为 #3A3A3C，主文字翻转为 rgba(255,255,255,0.9)。
 */
.wifi-card {
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
  padding: 3.2vw;
  border-radius: 1.07vw;
  border: 1px solid #e5e7eb;
  background-color: #ffffff;
  color: rgba(0, 0, 0, 0.9);
}

.header {
  display: flex;
  flex-direction: column;
  margin-bottom: 2vw;
}

.eyebrow {
  font-size: 3.2vw;
  line-height: 1.2;
  font-weight: 600;
  color: #0f8f57;
}

.title {
  margin-top: 1vw;
  font-size: 4.53vw;
  line-height: 1.25;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.9);
}

.body {
  display: flex;
  flex-direction: column;
}

.label {
  font-size: 3.2vw;
  line-height: 1.3;
  color: rgba(0, 0, 0, 0.45);
}

.name {
  margin-top: 1vw;
  font-size: 4vw;
  line-height: 1.35;
  font-weight: 600;
  color: rgba(0, 0, 0, 0.9);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.desc {
  margin-top: 1vw;
  font-size: 3.2vw;
  line-height: 1.35;
  color: rgba(0, 0, 0, 0.45);
}

.actions {
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  margin-top: 2vw;
}

.secondary-btn {
  box-sizing: border-box;
  min-width: 24vw;
  height: 10.67vw;
  padding: 0 3.2vw;
  border-radius: 1.07vw;
  border: 1px solid #0f8f57;
  background-color: #ffffff;
  color: #0f8f57;
  font-size: 4vw;
  line-height: 10.67vw;
  font-weight: 500;
}

.btn-hover {
  opacity: 0.72;
}

@media (prefers-color-scheme: dark) {
  .wifi-card {
    border-color: #3a3a3c;
    background-color: #181818;
    color: rgba(255, 255, 255, 0.9);
  }

  .title,
  .name {
    color: rgba(255, 255, 255, 0.9);
  }

  .label,
  .desc {
    color: rgba(255, 255, 255, 0.45);
  }

  .secondary-btn {
    background-color: #181818;
    color: #0f8f57;
    border-color: #0f8f57;
  }
}
